<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorWhite">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:background="#A6D3F2"
        android:fontFamily="@font/chango"
        android:gravity="center_horizontal"
        android:text="Cat Community"
        android:textColor="?attr/colorBackgroundFloating"
        android:textSize="25sp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/tv_refresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="340dp"
        android:layout_marginTop="6dp"
        android:text="刷新"
        android:textColor="#A6D3F2"
        android:background="@drawable/btn_white"
        android:textSize="18sp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/tv_student_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_title"
        android:layout_marginBottom="4dp"
        android:gravity="center_horizontal"
        android:textColor="@color/colorBlack"
        android:textSize="18sp"
        android:textStyle="italic" />

    <ImageButton
        android:id="@+id/ib_learning_use"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_below="@+id/tv_student_number"
        android:layout_marginStart="15dp"
        android:background="@color/colorWhite"
        android:scaleType="centerCrop"
        android:src="@drawable/icon_learning_use" />

    <ImageButton
        android:id="@+id/ib_electric_product"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_below="@+id/tv_student_number"
        android:layout_marginStart="110dp"
        android:background="@color/colorWhite"
        android:scaleType="centerCrop"
        android:src="@drawable/icon_electric_product" />

    <ImageButton
        android:id="@+id/ib_daily_use"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_below="@id/tv_student_number"
        android:layout_marginStart="205dp"
        android:background="@color/colorWhite"
        android:scaleType="centerCrop"
        android:src="@drawable/icon_daily_use" />

    <ImageButton
        android:id="@+id/ib_sports_good"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_below="@id/tv_student_number"
        android:layout_marginStart="310dp"
        android:background="@color/colorWhite"
        android:scaleType="centerCrop"
        android:src="@drawable/icon_sports_good" />

    <TextView
        android:id="@+id/tv_learning_use"
        android:layout_width="80dp"
        android:layout_height="30dp"
        android:layout_below="@+id/ib_learning_use"
        android:layout_marginStart="15dp"
        android:fontFamily="@font/aladin"
        android:text="Adoption Cats"
        android:textAlignment="center"
        android:textColor="@color/colorBlack"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_electric_product"
        android:layout_width="80dp"
        android:layout_height="25dp"
        android:layout_below="@+id/ib_electric_product"
        android:layout_marginStart="110dp"
        android:fontFamily="@font/nova_square"
        android:text="Cat's Story"
        android:textAlignment="center"
        android:textColor="@color/colorBlack"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_daily_use"
        android:layout_width="80dp"
        android:layout_height="25dp"
        android:layout_below="@+id/ib_daily_use"
        android:layout_marginStart="205dp"
        android:fontFamily="@font/nova_square"
        android:text="Cat's Food"
        android:textAlignment="center"
        android:textColor="@color/colorBlack"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_sports_good"
        android:layout_width="80dp"
        android:layout_height="25dp"
        android:layout_below="@+id/ib_sports_good"
        android:layout_marginStart="310dp"
        android:fontFamily="@font/nova_square"
        android:text="CatTranslate"
        android:textAlignment="center"
        android:textColor="@color/colorBlack"
        android:textSize="14sp"
        android:textStyle="bold" />

    <android.support.v4.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:layout_above="@+id/view2"
        android:layout_below="@+id/tv_electric_product">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.leaf.collegeidleapp.view.ListViewInScrollView
                android:id="@+id/lv_all_commodity"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="-1dp"/>
        </LinearLayout>
    </android.support.v4.widget.NestedScrollView>

    <View
        android:id="@+id/view1"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_above="@+id/view2"
        android:layout_marginTop="70dp"
        android:background="@color/colorBlack" />

    <ImageButton
        android:id="@+id/ib_home_page"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_above="@+id/tv_home_page"
        android:layout_marginStart="50dp"
        android:layout_marginTop="5dp"
        android:src="@drawable/icon_home_page" />

    <View
        android:id="@+id/view2"
        android:layout_width="2dp"
        android:layout_height="60dp"
        android:layout_above="@+id/view4"
        android:layout_marginStart="130dp"
        android:background="@color/colorBlack" />

    <ImageButton
        android:id="@+id/ib_add_product"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_above="@+id/tv_add_product"
        android:layout_marginStart="180dp"
        android:layout_marginTop="5dp"
        android:src="@drawable/icon_add_product" />

    <View
        android:id="@+id/view3"
        android:layout_width="2dp"
        android:layout_height="60dp"
        android:layout_above="@+id/view4"
        android:layout_marginStart="270dp"
        android:background="@color/colorBlack" />

    <ImageButton
        android:id="@+id/ib_personal_center"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_above="@+id/tv_personal_center"
        android:layout_marginStart="320dp"
        android:layout_marginTop="5dp"
        android:src="@drawable/icon_personal_center" />

    <TextView
        android:id="@+id/tv_home_page"
        android:layout_width="35dp"
        android:layout_height="20dp"
        android:layout_above="@+id/view4"
        android:layout_marginStart="50dp"
        android:layout_marginBottom="5dp"
        android:text="首页"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_add_product"
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:layout_above="@+id/view4"
        android:layout_marginStart="165dp"
        android:layout_marginBottom="8dp"
        android:text="发帖"
        android:textAlignment="center"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_personal_center"
        android:layout_width="63dp"
        android:layout_height="wrap_content"
        android:layout_above="@+id/view4"
        android:layout_marginStart="305dp"
        android:layout_marginBottom="8dp"
        android:text="我的"
        android:textAlignment="center"
        android:textSize="15sp"
        android:textStyle="bold" />

    <View
        android:id="@+id/view4"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_alignParentBottom="true"
        android:background="@color/colorBlack" />
</RelativeLayout>